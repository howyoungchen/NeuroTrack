    <string name="mindfulness_title">正念练习</string>
    <string name="mindfulness_desc">六节引导音频保存在本机。每节完整播放一次即计入本轮，也可以随时重听。</string>
    <string name="mindfulness_courses_entry">查看本轮课程</string>
    <string name="mindfulness_courses_title">本轮课程</string>
    <string name="mindfulness_lesson_completed">已完成</string>
    <string name="mindfulness_source_credit">音频由 NSW Multicultural Health Communication Service 提供；中文界面播放普通话版。</string>
    <string name="mindfulness_start_lesson">开始本节</string>
    <string name="mindfulness_replay">重新播放</string>
    <string name="mindfulness_lesson_1_title">感官觉察落地练习</string>
    <string name="mindfulness_lesson_1_desc">借助五种感官回到此刻，重新连接身体、思绪与周围环境。</string>
    <string name="mindfulness_lesson_1_duration">约 8 分钟</string>
    <string name="mindfulness_lesson_2_title">正念呼吸</string>
    <string name="mindfulness_lesson_2_desc">觉察呼吸与身体感受，辨认并滋养有帮助的想法，让思绪慢慢清晰。</string>
    <string name="mindfulness_lesson_2_duration">约 7–9 分钟</string>
    <string name="mindfulness_lesson_3_title">身体扫描</string>
    <string name="mindfulness_lesson_3_desc">逐步觉察身体各处的感受，在不评判中放松紧绷并照顾整体状态。</string>
    <string name="mindfulness_lesson_3_duration">约 10–14 分钟</string>
    <string name="mindfulness_lesson_4_title">溪流上的树叶</string>
    <string name="mindfulness_lesson_4_desc">观察念头出现、停留与离开，练习用新的方式回应它们。</string>
    <string name="mindfulness_lesson_4_duration">约 8–11 分钟</string>
    <string name="mindfulness_lesson_5_title">慈爱与自我关怀</string>
    <string name="mindfulness_lesson_5_desc">把善意与关怀送给自己、所爱的人，以及生活中不容易相处的人。</string>
    <string name="mindfulness_lesson_5_duration">约 11–15 分钟</string>
    <string name="mindfulness_lesson_6_title">与困难情绪共处</string>
    <string name="mindfulness_lesson_6_desc">为痛苦情绪留出空间，练习以更有帮助的方式理解和回应它们。</string>
    <string name="mindfulness_lesson_6_duration">约 12–17 分钟</string>

